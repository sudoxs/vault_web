---
permalink: /assets/search_index.json
---
{
  "generated": {{ site.time | date_to_xmlschema | jsonify }},
  "content_dir": {{ site.content_dir | jsonify }},
  "pages": [
    {%- assign all_pages = site.pages | where_exp:"p","p.url != '/assets/search_index.json'" -%}
    {%- assign comma = false -%}
    {%- for p in all_pages -%}
      {%- if p.exclude_from_nav != true -%}
        {%- if comma -%},{%- endif -%}
        {
          "type": "page",
          "title": {{ p.title | default: p.name | jsonify }},
          "url": {{ p.url | jsonify }},
          "path": {{ p.path | jsonify }},
          "body": {{ p.content | strip_html | strip_newlines | replace: "  ", " " | truncate: 4000 | jsonify }}
        }
        {%- assign comma = true -%}
      {%- endif -%}
    {%- endfor -%}
  ],
  "files": [
    {%- assign content_path = "/" | append: site.content_dir | append: "/" -%}
    {%- assign static = site.static_files | where_exp:"f","f.path contains content_path" -%}
    {%- for f in static -%}
      {
        "type": "file",
        "name": {{ f.name | jsonify }},
        "url": {{ f.path | jsonify }},
        "path": {{ f.path | jsonify }}
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
